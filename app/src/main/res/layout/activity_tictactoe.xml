<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".TicTacToeActivity">

    <!-- Player 2 (O) Info at Top -->
    <LinearLayout
        android:id="@+id/player2Layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/exitButtonTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Exit Game"
            android:layout_marginEnd="8dp"
            android:rotation="180"/>

        <TextView
            android:id="@+id/statusTextTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Turn: X"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.bagicode.games.tictactoe.TicTacToeView
        android:id="@+id/ticTacToeView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/player2Layout"
        app:layout_constraintBottom_toTopOf="@id/player1Layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginVertical="32dp"/>

    <!-- Player 1 (X) Info at Bottom -->
    <LinearLayout
        android:id="@+id/player1Layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/exitButtonBottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Exit Game"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/statusTextBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Turn: X"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
