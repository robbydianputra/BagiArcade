<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".chess.ChessActivity">

    <!-- Player 2 (Black) Info at Top -->
    <LinearLayout
        android:id="@+id/player2Layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/exitButtonTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Exit Game"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/player2Timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLACK: 05:00"
            android:textSize="20sp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/resignButton2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resign"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/settingsButtonTop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusTextTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turn: WHITE"
        android:textSize="18sp"
        android:textStyle="bold"
        android:rotation="180"
        app:layout_constraintTop_toBottomOf="@id/player2Layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <com.bagicode.games.chess.view.ChessView
        android:id="@+id/chessView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/statusTextTop"
        app:layout_constraintBottom_toTopOf="@id/statusTextBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:id="@+id/statusTextBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turn: WHITE"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/player1Layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- Player 1 (White) Info at Bottom -->
    <LinearLayout
        android:id="@+id/player1Layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/exitButtonBottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Exit Game"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/player1Timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WHITE: 05:00"
            android:textSize="20sp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/resignButton1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resign"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/settingsButtonBottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
